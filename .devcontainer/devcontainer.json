{
    "name": "Python Project",
    "image": "mcr.microsoft.com/devcontainers/python:3.13",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "installTool": "uv"
        }
    },
    "postCreateCommand": "pip install -e .",
    "customizations": {
        "vscode": {
            "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
        }
    }
}
